{
  "name": "metro",
  "version": "1.0.0",
  "description": "",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "dev": "nodemon --watch src --ext ts --exec ts-node src/index.ts",
    "dev:debug": "nodemon --watch src --ext ts --exec 'NODE_OPTIONS=\"--inspect=0.0.0.0:${DEBUG_PORT:-9229}\" ts-node src/index.ts'",
    "lint": "eslint src --ext .ts",
    "test": "jest",
    "migrate": "knex --knexfile knexfile.ts migrate:latest",
    "migrate:rollback": "knex --knexfile knexfile.ts migrate:rollback",
    "migrate:status": "knex --knexfile knexfile.ts migrate:status",
    "seed": "knex --knexfile knexfile.ts seed:run"
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "prom-client": "^15.1.3",
    "express": "^4.19.2",
    "knex": "^3.2.9",
    "mysql2": "^3.22.1",
    "swagger-ui-express": "^5.0.1",
    "yamljs": "^0.3.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^30.0.0",
    "@types/knex": "^0.15.2",
    "@types/node": "^20.14.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/yamljs": "^0.2.34",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.2",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "ts-node": "^10.9.2",
    "typescript": "^5.5.3"
  },
  "private": true
}
