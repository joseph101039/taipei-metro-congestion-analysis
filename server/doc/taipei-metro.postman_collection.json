          "response": []
        },
        {
          "name": "Get station by code - BL12 (忠孝復興)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/stations/BL12",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "BL12"]
            }
          },
          "response": []
        },
        {
          "name": "Get station by code - not found",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/stations/XX99",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "XX99"]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Station Distances",
      "item": [
        {
          "name": "List all station distances",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"]
            }
          },
          "response": []
        },
        {
          "name": "Filter by from_code=R28",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances?from_code=R28",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"],
              "query": [
                { "key": "from_code", "value": "R28" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by from_name=淡水",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances?from_name=淡水",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"],
              "query": [
                { "key": "from_name", "value": "淡水" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by to_code=R27",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances?to_code=R27",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"],
              "query": [
                { "key": "to_code", "value": "R27" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by to_name=紅樹林",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances?to_name=紅樹林",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"],
              "query": [
                { "key": "to_name", "value": "紅樹林" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by from_code + to_code",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances?from_code=R28&to_code=R27",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"],
              "query": [
                { "key": "from_code", "value": "R28" },
                { "key": "to_code", "value": "R27" }
              ]
            }
          },
          "response": []
        },
        {
          "name": "Filter by unknown from_code (empty result)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/station-distances?from_code=XX99",
              "host": ["{{baseUrl}}"],
              "path": ["station-distances"],
              "query": [
                { "key": "from_code", "value": "XX99" }
              ]
            }
          },
          "response": []
        }
      ]
    },
