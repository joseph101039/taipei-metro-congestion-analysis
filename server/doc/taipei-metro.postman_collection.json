{
  "info": {
    "name": "Taipei Metro API",
    "description": "REST API for the Taipei MRT (捷運) transit system.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000/api",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Lines",
      "item": [
        {
          "name": "List all lines",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lines",
              "host": ["{{baseUrl}}"],
              "path": ["lines"]
            }
          },
          "response": []
        },
        {
          "name": "Get line by code - red",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lines/red",
              "host": ["{{baseUrl}}"],
              "path": ["lines", "red"]
            }
          },
          "response": []
        },
        {
          "name": "Get line by code - blue",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lines/blue",
              "host": ["{{baseUrl}}"],
              "path": ["lines", "blue"]
            }
          },
          "response": []
        },
        {
          "name": "Get line by code - green",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lines/green",
              "host": ["{{baseUrl}}"],
              "path": ["lines", "green"]
            }
          },
          "response": []
        },
        {
          "name": "Get line by code - red_xinbeitou (branch)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lines/red_xinbeitou",
              "host": ["{{baseUrl}}"],
              "path": ["lines", "red_xinbeitou"]
            }
          },
          "response": []
        },
        {
          "name": "Get line by code - not found",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/lines/nonexistent",
              "host": ["{{baseUrl}}"],
              "path": ["lines", "nonexistent"]
            }
          },
          "response": []
        }
      ]
    },
    {
