          },
          "response": []
        },
        {
          "name": "Get station by code - R28 (淡水)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/stations/R28",
              "host": ["{{baseUrl}}"],
              "path": ["stations", "R28"]
